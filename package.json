    "retroachievements",
    "retro-gaming",
    "claude"
  ],
  "author": "Zach Houston",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zach-Houston/retroachievements-mcp.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@retroachievements/api": "^2.10.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
