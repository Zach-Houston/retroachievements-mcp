{
  "name": "retroachievements-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the RetroAchievements API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "retroachievements-mcp": "dist/index.js",
    "retroachievements-mcp-setup": "dist/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx src/setup.ts",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
